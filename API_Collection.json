								{
									"key": "end_time",
									"value": "2026-04-30T23:59:59.000Z",
									"type": "text",
									"description": "End time in ISO 8601 format"
								},
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/content/upload",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"content",
								"upload"
							]
						}
					}
				},
				{
					"name": "Get My Content",
