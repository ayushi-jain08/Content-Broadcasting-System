									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"rejected\",\n    \"rejection_reason\": \"Incorrect subject category\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/content/{{contentId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"content",
								"{{contentId}}",
								"status"
							]
						}
					}
				}
			]
