		},
		{
			"name": "Principal Endpoints",
			"item": [
				{
					"name": "List All Content (Filters & Pagination)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/content/all?status=uploaded&subject=Maths&page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"content",
								"all"
							],
							"query": [
								{
									"key": "status",
									"value": "uploaded"
								},
								{
									"key": "subject",
									"value": "Maths"
								},
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					}
				},
				{
					"name": "Approve Content",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"approved\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/content/{{contentId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"content",
								"{{contentId}}",
								"status"
							]
						}
					}
				},
				{
					"name": "Reject Content",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
